{
  "version": 1,
  "hooks": {
    "beforeSubmitPrompt": [
      {
        "command": "\"C:\\Path\\To\\Cursor Light.exe\" --hook --event=beforeSubmitPrompt --status=yellow"
      }
    ],
    "beforeShellExecution": [
      {
        "command": "\"C:\\Path\\To\\Cursor Light.exe\" --hook --event=beforeShellExecution --status=yellow"
      }
    ],
    "beforeMCPExecution": [
      {
        "command": "\"C:\\Path\\To\\Cursor Light.exe\" --hook --event=beforeMCPExecution --status=yellow"
      }
    ],
    "afterAgentThought": [
      {
        "command": "\"C:\\Path\\To\\Cursor Light.exe\" --hook --event=afterAgentThought --status=yellow"
      }
    ],
    "afterShellExecution": [
      {
        "command": "\"C:\\Path\\To\\Cursor Light.exe\" --hook --event=afterShellExecution --status=yellow"
      }
    ],
    "afterFileEdit": [
      {
        "command": "\"C:\\Path\\To\\Cursor Light.exe\" --hook --event=afterFileEdit --status=yellow"
      }
    ],
    "afterAgentResponse": [
      {
        "command": "\"C:\\Path\\To\\Cursor Light.exe\" --hook --event=afterAgentResponse --status=green"
      }
    ],
    "stop": [
      {
        "command": "\"C:\\Path\\To\\Cursor Light.exe\" --hook --event=stop --status=green"
      }
    ]
  }
}
