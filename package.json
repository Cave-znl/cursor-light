{
  "name": "cursor-light",
  "version": "0.1.0",
  "description": "Desktop traffic light panel for Cursor hook events.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Cave-znl/cursor-light.git"
  },
  "scripts": {
    "start": "tauri dev",
    "dev": "tauri dev",
    "icon": "node scripts/generate-icon.js",
    "dist": "tauri build --no-bundle && node scripts/copy-tauri-release.js",
    "dist:installer": "tauri build --bundles nsis",
    "simulate:green": "powershell -NoProfile -Command \"Invoke-RestMethod -Uri http://127.0.0.1:18765/hook -Method Post -ContentType application/json -Body '{\\\"event\\\":\\\"after\\\",\\\"status\\\":\\\"green\\\"}'\"",
    "simulate:yellow": "powershell -NoProfile -Command \"Invoke-RestMethod -Uri http://127.0.0.1:18765/hook -Method Post -ContentType application/json -Body '{\\\"event\\\":\\\"before\\\",\\\"status\\\":\\\"yellow\\\"}'\"",
    "simulate:red": "powershell -NoProfile -Command \"Invoke-RestMethod -Uri http://127.0.0.1:18765/hook -Method Post -ContentType application/json -Body '{\\\"event\\\":\\\"error\\\",\\\"status\\\":\\\"red\\\"}'\""
  },
  "keywords": [
    "cursor",
    "hooks",
    "tauri",
    "traffic-light"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0"
  }
}
